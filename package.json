{
  "name": "klack-generate-monorepo",
  "version": "1.0.0",
  "description": "Scaffold a production-grade full-stack TypeScript monorepo with Bun, Turborepo, NestJS, Next.js, and Expo",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "klack-generate-monorepo": "./dist/cli.js",
    "klack-generate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run type-check"
  },
  "keywords": [
    "cli",
    "scaffold",
    "monorepo",
    "typescript",
    "nestjs",
    "nextjs",
    "expo",
    "turborepo",
    "bun"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ]
}
